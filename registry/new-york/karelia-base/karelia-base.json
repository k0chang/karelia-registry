{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "karelia-base",
  "type": "registry:base",
  "description": "Karelia — A Nordic Brutalist design system. Deep teal foundations with electric cyan accents, bold typography, and dramatic spatial composition.",
  "author": "karelia-registry",
  "config": {
    "style": "karelia",
    "iconLibrary": "lucide",
    "tailwind": {
      "baseColor": "neutral"
    },
    "aliases": {
      "components": "@/components",
      "utils": "@/lib/utils",
      "ui": "@/components/ui",
      "lib": "@/lib",
      "hooks": "@/hooks"
    }
  },
  "dependencies": [
    "class-variance-authority",
    "tw-animate-css",
    "lucide-react",
    "clsx",
    "tailwind-merge",
    "@fontsource-variable/inter",
    "@fontsource-variable/jetbrains-mono"
  ],
  "registryDependencies": ["utils"],
  "cssVars": {
    "theme": {
      "font-sans": "'Inter Variable', 'Inter', ui-sans-serif, system-ui, sans-serif",
      "font-mono": "'JetBrains Mono Variable', 'JetBrains Mono', ui-monospace, monospace",
      "--animate-enter": "enter 0.3s cubic-bezier(0.16, 1, 0.3, 1)",
      "--animate-exit": "exit 0.2s cubic-bezier(0.7, 0, 0.84, 0)",
      "--animate-pulse-glow": "pulse-glow 2s cubic-bezier(0.4, 0, 0.6, 1) infinite",
      "--animate-slide-up": "slide-up 0.4s cubic-bezier(0.16, 1, 0.3, 1)",
      "--animate-fade-in": "fade-in 0.3s ease-out"
    },
    "light": {
      "background": "oklch(0.97 0.005 200)",
      "foreground": "oklch(0.15 0.03 220)",
      "card": "oklch(0.99 0.002 200)",
      "card-foreground": "oklch(0.15 0.03 220)",
      "popover": "oklch(0.99 0.002 200)",
      "popover-foreground": "oklch(0.15 0.03 220)",
      "primary": "oklch(0.35 0.12 195)",
      "primary-foreground": "oklch(0.98 0.01 195)",
      "secondary": "oklch(0.92 0.02 200)",
      "secondary-foreground": "oklch(0.25 0.06 210)",
      "muted": "oklch(0.94 0.01 200)",
      "muted-foreground": "oklch(0.50 0.03 210)",
      "accent": "oklch(0.72 0.19 190)",
      "accent-foreground": "oklch(0.13 0.04 210)",
      "destructive": "oklch(0.55 0.22 27)",
      "destructive-foreground": "oklch(0.98 0.01 27)",
      "border": "oklch(0.88 0.02 200)",
      "input": "oklch(0.88 0.02 200)",
      "ring": "oklch(0.60 0.16 190)",
      "chart-1": "oklch(0.55 0.18 195)",
      "chart-2": "oklch(0.65 0.20 165)",
      "chart-3": "oklch(0.60 0.15 270)",
      "chart-4": "oklch(0.70 0.17 55)",
      "chart-5": "oklch(0.55 0.22 27)",
      "sidebar-background": "oklch(0.18 0.04 210)",
      "sidebar-foreground": "oklch(0.88 0.02 200)",
      "sidebar-primary": "oklch(0.72 0.19 190)",
      "sidebar-primary-foreground": "oklch(0.13 0.04 210)",
      "sidebar-accent": "oklch(0.25 0.05 210)",
      "sidebar-accent-foreground": "oklch(0.88 0.02 200)",
      "sidebar-border": "oklch(0.28 0.04 210)",
      "sidebar-ring": "oklch(0.60 0.16 190)"
    },
    "dark": {
      "background": "oklch(0.13 0.03 220)",
      "foreground": "oklch(0.93 0.01 200)",
      "card": "oklch(0.17 0.035 215)",
      "card-foreground": "oklch(0.93 0.01 200)",
      "popover": "oklch(0.17 0.035 215)",
      "popover-foreground": "oklch(0.93 0.01 200)",
      "primary": "oklch(0.72 0.19 190)",
      "primary-foreground": "oklch(0.13 0.04 210)",
      "secondary": "oklch(0.22 0.04 215)",
      "secondary-foreground": "oklch(0.88 0.02 200)",
      "muted": "oklch(0.22 0.03 215)",
      "muted-foreground": "oklch(0.60 0.03 210)",
      "accent": "oklch(0.72 0.19 190)",
      "accent-foreground": "oklch(0.13 0.04 210)",
      "destructive": "oklch(0.60 0.22 27)",
      "destructive-foreground": "oklch(0.98 0.01 27)",
      "border": "oklch(0.28 0.04 215)",
      "input": "oklch(0.28 0.04 215)",
      "ring": "oklch(0.72 0.19 190)",
      "chart-1": "oklch(0.72 0.19 190)",
      "chart-2": "oklch(0.70 0.20 165)",
      "chart-3": "oklch(0.65 0.17 270)",
      "chart-4": "oklch(0.75 0.17 55)",
      "chart-5": "oklch(0.60 0.22 27)",
      "sidebar-background": "oklch(0.10 0.025 220)",
      "sidebar-foreground": "oklch(0.88 0.02 200)",
      "sidebar-primary": "oklch(0.72 0.19 190)",
      "sidebar-primary-foreground": "oklch(0.13 0.04 210)",
      "sidebar-accent": "oklch(0.20 0.04 215)",
      "sidebar-accent-foreground": "oklch(0.88 0.02 200)",
      "sidebar-border": "oklch(0.22 0.035 215)",
      "sidebar-ring": "oklch(0.72 0.19 190)"
    }
  },
  "css": {
    "@import \"tw-animate-css\"": {},
    "@keyframes pulse-glow": {
      "0%, 100%": {
        "box-shadow": "0 0 0 0 oklch(0.72 0.19 190 / 0)"
      },
      "50%": {
        "box-shadow": "0 0 20px 4px oklch(0.72 0.19 190 / 0.3)"
      }
    },
    "@keyframes slide-up": {
      "from": {
        "opacity": "0",
        "transform": "translateY(8px)"
      },
      "to": {
        "opacity": "1",
        "transform": "translateY(0)"
      }
    },
    "@keyframes fade-in": {
      "from": {
        "opacity": "0"
      },
      "to": {
        "opacity": "1"
      }
    },
    "@keyframes shimmer": {
      "0%": {
        "background-position": "-200% 0"
      },
      "100%": {
        "background-position": "200% 0"
      }
    },
    "@layer base": {
      "*": {
        "@apply border-border outline-ring/50": {}
      },
      "body": {
        "@apply bg-background text-foreground antialiased": {}
      },
      "h1, h2, h3, h4, h5, h6": {
        "@apply font-semibold tracking-tight text-foreground": {}
      },
      "h1": {
        "@apply text-4xl font-bold lg:text-5xl": {}
      },
      "h2": {
        "@apply text-3xl lg:text-4xl": {}
      },
      "h3": {
        "@apply text-2xl lg:text-3xl": {}
      },
      "code, kbd, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  }
}
