{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "karelia",
  "homepage": "https://karelia-registry.ehlersiana.workers.dev",
  "items": [
    {
      "name": "button",
      "type": "registry:ui",
      "title": "Button",
      "description": "A versatile button component with multiple variants and sizes. Built on @base-ui/react primitives.",
      "dependencies": ["@base-ui/react", "class-variance-authority"],
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "registry/new-york/button/button.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "input",
      "type": "registry:ui",
      "title": "Input",
      "description": "A styled text input component built on @base-ui/react Input primitive.",
      "dependencies": ["@base-ui/react"],
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "registry/new-york/input/input.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "label",
      "type": "registry:ui",
      "title": "Label",
      "description": "An accessible label component for form controls.",
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "registry/new-york/label/label.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "card",
      "type": "registry:ui",
      "title": "Card",
      "description": "A card component with header, content, and footer sections for grouping related content.",
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "registry/new-york/card/card.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "date-utils",
      "type": "registry:lib",
      "title": "Date Utils",
      "description": "Date utility functions using native Intl API. Includes formatDate, toDate, isToday, daysBetween, formatRelative, and toISODateString.",
      "files": [
        {
          "path": "registry/new-york/date-utils/date-utils.ts",
          "type": "registry:lib"
        }
      ]
    },
    {
      "name": "use-debounce",
      "type": "registry:hook",
      "title": "useDebounce",
      "description": "A React hook that debounces a value by a specified delay. Useful for search inputs and API calls.",
      "files": [
        {
          "path": "registry/new-york/use-debounce/use-debounce.ts",
          "type": "registry:hook"
        }
      ]
    },
    {
      "name": "use-clipboard",
      "type": "registry:hook",
      "title": "useClipboard",
      "description": "A React hook for copying text to the clipboard with a temporary 'copied' state indicator.",
      "files": [
        {
          "path": "registry/new-york/use-clipboard/use-clipboard.ts",
          "type": "registry:hook"
        }
      ]
    },
    {
      "name": "login-form",
      "type": "registry:block",
      "title": "Login Form",
      "description": "A complete login form block with email/password fields and social login buttons (GitHub, Google).",
      "registryDependencies": ["button", "input", "label", "card"],
      "files": [
        {
          "path": "registry/new-york/login-form/page.tsx",
          "type": "registry:page",
          "target": "app/login/page.tsx"
        },
        {
          "path": "registry/new-york/login-form/login-form.tsx",
          "type": "registry:component"
        }
      ]
    },
    {
      "name": "karelia-base",
      "type": "registry:base",
      "title": "Karelia Base",
      "description": "Karelia — A Nordic Brutalist design system with deep teal foundations and electric cyan accents.",
      "author": "karelia-registry",
      "config": {
        "style": "karelia",
        "iconLibrary": "lucide",
        "tailwind": {
          "baseColor": "neutral"
        },
        "aliases": {
          "components": "@/components",
          "utils": "@/lib/utils",
          "ui": "@/components/ui",
          "lib": "@/lib",
          "hooks": "@/hooks"
        }
      },
      "dependencies": [
        "class-variance-authority",
        "tw-animate-css",
        "lucide-react",
        "clsx",
        "tailwind-merge",
        "@fontsource-variable/inter",
        "@fontsource-variable/jetbrains-mono"
      ],
      "registryDependencies": ["utils"],
      "cssVars": {
        "theme": {
          "font-sans": "'Inter Variable', 'Inter', ui-sans-serif, system-ui, sans-serif",
          "font-mono": "'JetBrains Mono Variable', 'JetBrains Mono', ui-monospace, monospace",
          "--animate-pulse-glow": "pulse-glow 2s cubic-bezier(0.4, 0, 0.6, 1) infinite",
          "--animate-slide-up": "slide-up 0.4s cubic-bezier(0.16, 1, 0.3, 1)",
          "--animate-fade-in": "fade-in 0.3s ease-out"
        },
        "light": {
          "background": "oklch(0.97 0.005 200)",
          "foreground": "oklch(0.15 0.03 220)",
          "card": "oklch(0.99 0.002 200)",
          "card-foreground": "oklch(0.15 0.03 220)",
          "popover": "oklch(0.99 0.002 200)",
          "popover-foreground": "oklch(0.15 0.03 220)",
          "primary": "oklch(0.35 0.12 195)",
          "primary-foreground": "oklch(0.98 0.01 195)",
          "secondary": "oklch(0.92 0.02 200)",
          "secondary-foreground": "oklch(0.25 0.06 210)",
          "muted": "oklch(0.94 0.01 200)",
          "muted-foreground": "oklch(0.50 0.03 210)",
          "accent": "oklch(0.72 0.19 190)",
          "accent-foreground": "oklch(0.13 0.04 210)",
          "destructive": "oklch(0.55 0.22 27)",
          "destructive-foreground": "oklch(0.98 0.01 27)",
          "border": "oklch(0.88 0.02 200)",
          "input": "oklch(0.88 0.02 200)",
          "ring": "oklch(0.60 0.16 190)",
          "chart-1": "oklch(0.55 0.18 195)",
          "chart-2": "oklch(0.65 0.20 165)",
          "chart-3": "oklch(0.60 0.15 270)",
          "chart-4": "oklch(0.70 0.17 55)",
          "chart-5": "oklch(0.55 0.22 27)",
          "sidebar-background": "oklch(0.18 0.04 210)",
          "sidebar-foreground": "oklch(0.88 0.02 200)",
          "sidebar-primary": "oklch(0.72 0.19 190)",
          "sidebar-primary-foreground": "oklch(0.13 0.04 210)",
          "sidebar-accent": "oklch(0.25 0.05 210)",
          "sidebar-accent-foreground": "oklch(0.88 0.02 200)",
          "sidebar-border": "oklch(0.28 0.04 210)",
          "sidebar-ring": "oklch(0.60 0.16 190)"
        },
        "dark": {
          "background": "oklch(0.13 0.03 220)",
          "foreground": "oklch(0.93 0.01 200)",
          "card": "oklch(0.17 0.035 215)",
          "card-foreground": "oklch(0.93 0.01 200)",
          "popover": "oklch(0.17 0.035 215)",
          "popover-foreground": "oklch(0.93 0.01 200)",
          "primary": "oklch(0.72 0.19 190)",
          "primary-foreground": "oklch(0.13 0.04 210)",
          "secondary": "oklch(0.22 0.04 215)",
          "secondary-foreground": "oklch(0.88 0.02 200)",
          "muted": "oklch(0.22 0.03 215)",
          "muted-foreground": "oklch(0.60 0.03 210)",
          "accent": "oklch(0.72 0.19 190)",
          "accent-foreground": "oklch(0.13 0.04 210)",
          "destructive": "oklch(0.60 0.22 27)",
          "destructive-foreground": "oklch(0.98 0.01 27)",
          "border": "oklch(0.28 0.04 215)",
          "input": "oklch(0.28 0.04 215)",
          "ring": "oklch(0.72 0.19 190)",
          "chart-1": "oklch(0.72 0.19 190)",
          "chart-2": "oklch(0.70 0.20 165)",
          "chart-3": "oklch(0.65 0.17 270)",
          "chart-4": "oklch(0.75 0.17 55)",
          "chart-5": "oklch(0.60 0.22 27)",
          "sidebar-background": "oklch(0.10 0.025 220)",
          "sidebar-foreground": "oklch(0.88 0.02 200)",
          "sidebar-primary": "oklch(0.72 0.19 190)",
          "sidebar-primary-foreground": "oklch(0.13 0.04 210)",
          "sidebar-accent": "oklch(0.20 0.04 215)",
          "sidebar-accent-foreground": "oklch(0.88 0.02 200)",
          "sidebar-border": "oklch(0.22 0.035 215)",
          "sidebar-ring": "oklch(0.72 0.19 190)"
        }
      },
      "css": {
        "@import \"tw-animate-css\"": {},
        "@keyframes pulse-glow": {
          "0%, 100%": {
            "box-shadow": "0 0 0 0 oklch(0.72 0.19 190 / 0)"
          },
          "50%": {
            "box-shadow": "0 0 20px 4px oklch(0.72 0.19 190 / 0.3)"
          }
        },
        "@keyframes slide-up": {
          "from": {
            "opacity": "0",
            "transform": "translateY(8px)"
          },
          "to": {
            "opacity": "1",
            "transform": "translateY(0)"
          }
        },
        "@keyframes fade-in": {
          "from": {
            "opacity": "0"
          },
          "to": {
            "opacity": "1"
          }
        },
        "@layer base": {
          "*": {
            "@apply border-border outline-ring/50": {}
          },
          "body": {
            "@apply bg-background text-foreground antialiased": {}
          },
          "h1, h2, h3, h4, h5, h6": {
            "@apply font-semibold tracking-tight text-foreground": {}
          },
          "code, kbd, pre": {
            "font-family": "var(--font-mono)"
          }
        }
      }
    }
  ]
}
